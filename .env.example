# ── Gemini Live API ──────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase 대시보드 > Project Settings > Database > Connection string (URI)에서 발급.
# 웹 어드민(sqladmin)이 PostgREST가 아니라 Postgres에 직접 붙기 위해 필요.
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# 어드민 세션 쿠키 서명용 시크릿. openssl rand -hex 32로 생성해서 운영 환경에서는 반드시 교체.
ADMIN_SESSION_SECRET=dev-only-change-me

# ── GCP ──────────────────────────────────────────────────────
GCS_BUCKET_NAME=preter-uploads
GCP_PROJECT_ID=your_gcp_project_id


# ── 서버 설정 ────────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
